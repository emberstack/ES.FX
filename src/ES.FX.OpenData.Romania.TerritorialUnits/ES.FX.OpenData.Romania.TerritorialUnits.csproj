<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Romanian territorial units (SIRUTA) reference dataset for ES.FX.OpenData: counties, UATs, and localities with clean display names, diacritic-insensitive search, and postal codes.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <ProjectReference Include="..\ES.FX\ES.FX.csproj" />
    <ProjectReference Include="..\ES.FX.OpenData.Countries\ES.FX.OpenData.Countries.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="ES.FX.OpenData.Romania.TerritorialUnits.Tests" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\siruta.2025-12.csv.gz">
      <LogicalName>ES.FX.OpenData.Romania.TerritorialUnits.siruta.2025-12.csv.gz</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
