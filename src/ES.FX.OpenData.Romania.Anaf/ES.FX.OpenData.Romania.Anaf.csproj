<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Typed client for the Romanian ANAF VAT-payer registry (PlatitorTvaRest v9), part of the ES.FX.OpenData family. Batch-native over IHttpClientFactory with a built-in request throttle.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Http" />
    <ProjectReference Include="..\ES.FX.OpenData.Romania.TerritorialUnits\ES.FX.OpenData.Romania.TerritorialUnits.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="ES.FX.OpenData.Romania.Anaf.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!-- Slim ANAF(MFP) locality-code → SIRUTA crosswalk, extracted verbatim from the Ministry of Finance
         geographic nomenclature (edition 2026-07). Generated + validated from the source XML; see the
         crosswalk generator under the datasets folder. -->
    <EmbeddedResource Include="..\datasets\opendata\romania\anaf\anaf-siruta.2026-07.json">
      <Link>Resources\anaf-siruta.2026-07.json</Link>
      <LogicalName>ES.FX.OpenData.Romania.Anaf.anaf-siruta.2026-07.json</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
