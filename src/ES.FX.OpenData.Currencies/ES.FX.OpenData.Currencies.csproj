<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>ISO 4217 currencies as baked-in .NET datasets: alpha-3 and numeric codes with localized names (en guaranteed) via services.AddCurrencies(). Also bundles the raw ISO 4217 dataset via services.AddIso4217().</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="ES.FX.OpenData.Currencies.Tests" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\datasets\opendata\iso\4217\iso_4217.json">
      <Link>Resources\iso_4217.json</Link>
      <LogicalName>ES.FX.OpenData.Currencies.ISO4217.iso_4217.json</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\datasets\opendata\currencies\currency-localized-names.json">
      <Link>Resources\currency-localized-names.json</Link>
      <LogicalName>ES.FX.OpenData.Currencies.currency-localized-names.json</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- CurrencyAlpha3Codes / CurrencyNumericCodes are generated at build time from the ISO 4217 dataset by
       CurrencyCodes.tt into obj/ (a build artifact — never committed, obj/ is git-ignored). GenerateCurrencyCodes
       self-restores the dotnet-t4 local tool so a plain `dotnet build` works from a fresh clone with no extra
       steps. It's incremental (Inputs/Outputs), so t4 only re-runs when the template or the ISO data changes. -->
  <Target Name="GenerateCurrencyCodes" BeforeTargets="CoreCompile"
          Inputs="CurrencyCodes.tt;..\datasets\opendata\iso\4217\iso_4217.json"
          Outputs="$(IntermediateOutputPath)CurrencyCodes.g.cs">
    <Exec Command="dotnet tool restore" WorkingDirectory="$(MSBuildProjectDirectory)" />
    <Exec Command="dotnet t4 CurrencyCodes.tt -o &quot;$(IntermediateOutputPath)CurrencyCodes.g.cs&quot;" WorkingDirectory="$(MSBuildProjectDirectory)" />
  </Target>
  <Target Name="IncludeGeneratedCurrencyCodes" BeforeTargets="CoreCompile" DependsOnTargets="GenerateCurrencyCodes">
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)CurrencyCodes.g.cs" />
    </ItemGroup>
  </Target>

</Project>
