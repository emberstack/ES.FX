<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Curated countries and their subdivisions as baked-in .NET datasets: ISO 3166-1 country codes with localized names (en, ro) via services.AddCountries(), and ISO 3166-2 subdivisions/regions via services.AddCountrySubdivisions(). Also bundles the raw ISO 3166 datasets (parts 1/2/3) via services.AddIso3166().</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\datasets\opendata\countries\country-localized-names.json">
      <Link>Resources\country-localized-names.json</Link>
      <LogicalName>ES.FX.OpenData.Countries.country-localized-names.json</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\datasets\opendata\countries\subdivision-localized-names.json">
      <Link>Resources\subdivision-localized-names.json</Link>
      <LogicalName>ES.FX.OpenData.Countries.subdivision-localized-names.json</LogicalName>
    </EmbeddedResource>
    <!-- ISO 3166 datasets (parts 1/2/3), merged in from the former ES.FX.OpenData.ISO3166 package.
         LogicalNames match the Resource constants in ISO3166/Internal/*Dataset.cs. -->
    <EmbeddedResource Include="..\datasets\opendata\iso\3166\iso_3166-1.json">
      <Link>Resources\iso_3166-1.json</Link>
      <LogicalName>ES.FX.OpenData.Countries.ISO3166.iso_3166-1.json</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\datasets\opendata\iso\3166\iso_3166-2.json">
      <Link>Resources\iso_3166-2.json</Link>
      <LogicalName>ES.FX.OpenData.Countries.ISO3166.iso_3166-2.json</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="..\datasets\opendata\iso\3166\iso_3166-3.json">
      <Link>Resources\iso_3166-3.json</Link>
      <LogicalName>ES.FX.OpenData.Countries.ISO3166.iso_3166-3.json</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- CountryAlpha2Codes / CountryAlpha3Codes are generated at build time from the ISO 3166-1 dataset by
       CountryCodes.tt into obj/ (a build artifact — never committed, obj/ is git-ignored). GenerateCountryCodes
       self-restores the dotnet-t4 local tool so a plain `dotnet build` works from a fresh clone with no extra
       steps. It's incremental (Inputs/Outputs), so t4 only re-runs when the template or the ISO data changes. -->
  <Target Name="GenerateCountryCodes" BeforeTargets="CoreCompile"
          Inputs="CountryCodes.tt;..\datasets\opendata\iso\3166\iso_3166-1.json"
          Outputs="$(IntermediateOutputPath)CountryCodes.g.cs">
    <Exec Command="dotnet tool restore" WorkingDirectory="$(MSBuildProjectDirectory)" />
    <Exec Command="dotnet t4 CountryCodes.tt -o &quot;$(IntermediateOutputPath)CountryCodes.g.cs&quot;" WorkingDirectory="$(MSBuildProjectDirectory)" />
  </Target>
  <Target Name="IncludeGeneratedCountryCodes" BeforeTargets="CoreCompile" DependsOnTargets="GenerateCountryCodes">
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)CountryCodes.g.cs" />
    </ItemGroup>
  </Target>

</Project>
