<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>ISO 3166-1 countries reference dataset for ES.FX.OpenData: names, alpha-2/alpha-3/numeric codes, localized names, and alias resolution.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <ProjectReference Include="..\ES.FX.OpenData\ES.FX.OpenData.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\countries.json">
      <LogicalName>ES.FX.OpenData.Countries.countries.json</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Resources\country-aliases.json">
      <LogicalName>ES.FX.OpenData.Countries.country-aliases.json</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
