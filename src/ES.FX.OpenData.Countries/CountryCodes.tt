<#+
    // Turns a country name into a valid, readable PascalCase C# identifier (diacritics stripped, punctuation removed).
    static string Identifier(string name)
    {
        var decomposed = name.Normalize(NormalizationForm.FormD);
        var sb = new StringBuilder(decomposed.Length);
        foreach (var ch in decomposed)
            if (CharUnicodeInfo.GetUnicodeCategory(ch) != UnicodeCategory.NonSpacingMark)
                sb.Append(ch);
        var ascii = sb.ToString().Normalize(NormalizationForm.FormC);
        var parts = Regex.Split(ascii, "[^A-Za-z0-9]+").Where(p => p.Length > 0);
        var id = string.Concat(parts.Select(p => char.ToUpperInvariant(p[0]) + p.Substring(1)));
        if (id.Length == 0) id = "_";
        if (char.IsDigit(id[0])) id = "_" + id;
        return id;
    }

    static string Xml(string s) => s.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");
#>
