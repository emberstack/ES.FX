<#@ import namespace="System.Text.RegularExpressions" #>
<#
    // Read the single source of country identity: the ISO 3166-1 dataset.
    var templateDir = Path.GetDirectoryName(Host.TemplateFile);
    var jsonPath = Path.GetFullPath(Path.Combine(
        templateDir, "..", "datasets", "opendata", "iso", "3166", "iso_3166-1.json"));
    using var doc = JsonDocument.Parse(File.ReadAllText(jsonPath));

    var rows = new List<(string Id, string Name, string Alpha2, string Alpha3, int Numeric)>();
    var used = new Dictionary<string, int>(StringComparer.Ordinal);
    foreach (var el in doc.RootElement.GetProperty("3166-1").EnumerateArray())
    {
        var alpha2 = el.GetProperty("alpha_2").GetString();
        var alpha3 = el.GetProperty("alpha_3").GetString();
        // The ISO numeric code is a zero-padded string ("040"); parse it to an int for the numeric constants.
        var numeric = int.Parse(el.GetProperty("numeric").GetString(), CultureInfo.InvariantCulture);
        // Prefer the friendly common name (e.g. "South Korea") over the formal name. This MUST stay in sync with
        // the runtime display-name rule in CountriesStore.Build (`source.CommonName ?? source.Name`) so generated
        // member names track Country.Name — guarded by Generated_member_names_derive_from_the_dataset_display_name.
        var name = el.TryGetProperty("common_name", out var cn) ? cn.GetString() : el.GetProperty("name").GetString();
        var id = Identifier(name);
        if (used.TryGetValue(id, out var n)) { used[id] = n + 1; id += alpha2; } else used[id] = 1;
        rows.Add((id, name, alpha2, alpha3, numeric));
    }
    rows = rows.OrderBy(r => r.Id, StringComparer.Ordinal).ToList();
#>
